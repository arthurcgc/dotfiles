{
  "enabledPlugins": {
    "gopls-lsp@claude-plugins-official": true
  },
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "permissions": {
    "allow": [
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",

      "Bash(git:*)",
      "Bash(ls:*)",
      "Bash(mkdir:*)",
      "Bash(mv:*)",
      "Bash(cp:*)",
      "Bash(head:*)",
      "Bash(curl:*)",
      "Bash(cat:*)",
      "Bash(docker compose:*)",
      "Bash(docker logs:*)",
      "Bash(docker ps:*)",
      "Bash(chmod +x:*)",
      "Bash(systemctl --user:*)",
      "Bash(python3:*)",
      "Bash(bash:*)",

      "mcp__mempalace__mempalace_status",
      "mcp__mempalace__mempalace_diary_read",
      "mcp__mempalace__mempalace_diary_write",
      "mcp__mempalace__mempalace_kg_query",
      "mcp__mempalace__mempalace_kg_add",
      "mcp__mempalace__mempalace_kg_invalidate",
      "mcp__mempalace__mempalace_search",
      "mcp__mempalace__mempalace_kg_timeline",
      "mcp__mempalace__mempalace_graph_stats",
      "mcp__mempalace__mempalace_list_wings",
      "mcp__mempalace__mempalace_list_rooms",
      "mcp__mempalace__mempalace_find_tunnels",
      "mcp__mempalace__mempalace_traverse",
      "mcp__mempalace__mempalace_get_aaak_spec",
      "mcp__mempalace__mempalace_get_taxonomy",

      "mcp__docker__list_containers",
      "mcp__docker__list_images",
      "mcp__docker__container_logs",
      "mcp__docker__container_stats",
      "mcp__docker__exec_command",
      "mcp__docker__restart_container",

      "mcp__github__get_me",
      "mcp__github__get_latest_release",
      "mcp__github__get_file_contents",
      "mcp__github__get_commit",
      "mcp__github__list_commits",
      "mcp__github__list_branches",
      "mcp__github__list_issues",
      "mcp__github__list_pull_requests",
      "mcp__github__list_releases",
      "mcp__github__list_tags",
      "mcp__github__issue_read",
      "mcp__github__pull_request_read",
      "mcp__github__search_code",
      "mcp__github__search_issues",
      "mcp__github__search_pull_requests",
      "mcp__github__search_repositories",

      "mcp__mermaid__validate_and_render_mermaid_diagram",
      "mcp__mermaid__get_diagram_summary",
      "mcp__mermaid__get_diagram_title",
      "mcp__mermaid__get_mermaid_syntax_document",
      "mcp__mermaid__list_tools",
      "mcp__mermaid__search_mermaid_icons",

      "mcp__k8s__describe_kubectl",
      "mcp__k8s__describe_helm",
      "mcp__k8s__describe_istioctl",
      "mcp__k8s__describe_argocd",
      "mcp__k8s__execute_kubectl",
      "mcp__k8s__execute_helm",
      "mcp__k8s__execute_istioctl",
      "mcp__k8s__execute_argocd",

      "mcp__glances__authenticate"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mempalace-wakeup.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "resume",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.claude/hooks/mempalace-wakeup.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
