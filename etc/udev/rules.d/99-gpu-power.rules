# Allow user to control GPU power management without sudo
# Install: sudo cp this file to /etc/udev/rules.d/ && sudo udevadm control --reload-rules

# AMD GPU power profile mode
SUBSYSTEM=="drm", DRIVERS=="amdgpu", ATTR{device/pp_power_profile_mode}!="", RUN+="/bin/chmod 0666 /sys%p/device/pp_power_profile_mode"
# AMD GPU performance level
SUBSYSTEM=="drm", DRIVERS=="amdgpu", ATTR{device/power_dpm_force_performance_level}!="", RUN+="/bin/chmod 0666 /sys%p/device/power_dpm_force_performance_level"
